  { id:'m4', cat:'side', name:'Harina', amount:'1 taza', usedIn:'Jalapeño Mac & Cheese', notes:'Para el roux', extra:false, comprar:true },
  { id:'m5', cat:'side', name:'Mantequilla', amount:'8 oz / 2 barras', usedIn:'Jalapeño Mac & Cheese', notes:'Para el roux', extra:false, comprar:true },
  { id:'m6', cat:'side', name:'Cream cheese', amount:'32 oz total', usedIn:'Mac & Cheese · Mousse', notes:'16 oz para mac & cheese · 16 oz para mousse', extra:false, comprar:true },
  { id:'m7', cat:'side', name:'Queso Papa Pinto & Cheddar', amount:'3 lb total', usedIn:'Jalapeño Mac & Cheese', notes:'Queso principal', extra:false, comprar:true },
  { id:'m8', cat:'side', name:'Jalapeño', amount:'6–8 unidades', usedIn:'Jalapeño Mac & Cheese', notes:'Picante y sabor', extra:false, comprar:true },

  // COLESLAW + DRESSING
  { id:'c1', cat:'coleslaw', name:'Repollo verde', amount:'2 cabezas medianas (~3 lb)', usedIn:'Coleslaw Caribeño', notes:'Base del slaw · 3–4 oz por persona', extra:false, comprar:true },
  { id:'c2', cat:'coleslaw', name:'Cebolla lila', amount:'1 grande', usedIn:'Coleslaw Caribeño', notes:'Cortar fina', extra:false, comprar:true },
  { id:'c3', cat:'coleslaw', name:'Zanahoria', amount:'1 lb', usedIn:'Coleslaw Caribeño', notes:'Rallada o julienne', extra:false, comprar:true },
  { id:'c4', cat:'coleslaw', name:'Cilantro', amount:'1–2 bunches', usedIn:'Coleslaw Caribeño', notes:'Fresco', extra:false, comprar:true },
  { id:'c5', cat:'coleslaw', name:'Piña fresca', amount:'1 entera o 2 lb cortada', usedIn:'Coleslaw Caribeño', notes:'Para dulzor natural', extra:false, comprar:true },
  { id:'c6', cat:'coleslaw', name:'Apple cider vinegar', amount:'½ taza', usedIn:'Coleslaw dressing', notes:'Para acidez del dressing', extra:false, comprar:true },
  { id:'c7', cat:'coleslaw', name:'Aceite de oliva', amount:'½ taza', usedIn:'Coleslaw dressing', notes:'Para emulsión', extra:false, comprar:true },
  { id:'c8', cat:'coleslaw', name:'Pimienta negra', amount:'Al gusto', usedIn:'Coleslaw dressing', notes:'Opcional para el dressing', extra:true, comprar:false },

  // POSTRE
  { id:'d1', cat:'postre', name:'Bizcocho de maíz', amount:'1 bandeja 9×13 o equivalente', usedIn:'Postre', notes:'Base del postre · 1 porción por persona', extra:false, comprar:true },
  { id:'d2', cat:'postre', name:'Azúcar blanca', amount:'2 tazas total', usedIn:'Simple syrup · Mousse', notes:'1 taza para syrup · 1 taza para mousse', extra:false, comprar:true },
  { id:'d3', cat:'postre', name:'Canela completa (palitos)', amount:'2–3 palitos', usedIn:'Simple syrup', notes:'Para infusionar el syrup', extra:false, comprar:true },
  { id:'d4', cat:'postre', name:'Clavos', amount:'8–10 unidades', usedIn:'Simple syrup', notes:'Para infusionar el syrup', extra:false, comprar:true },
  { id:'d5', cat:'postre', name:'Agua', amount:'1 taza', usedIn:'Simple syrup', notes:'Necesaria para hacer el simple syrup', extra:true, comprar:false },
  { id:'d6', cat:'postre', name:'Vanilla extract', amount:'2 tsp', usedIn:'Mousse cream cheese', notes:'Sabor del mousse', extra:false, comprar:true },

  // MISCELLANEOUS
  { id:'x1', cat:'miscellaneous', name:'Bandejas de aluminio', amount:'3–5 bandejas grandes', usedIn:'Servicio / Cocina', notes:'Para cocinar o servir', extra:false, comprar:true },
  { id:'x2', cat:'miscellaneous', name:'Palitos de madera', amount:'1 paquete', usedIn:'Corn Ribs / Servicio', notes:'Para corn ribs o presentación', extra:false, comprar:true },
  { id:'x3', cat:'miscellaneous', name:'Papel aluminio', amount:'1 roll grande', usedIn:'Costillas / Cocina', notes:'Para cubrir o asar', extra:false, comprar:true },
];

const EXTRAS_NOTES = [
  { name:'Sal', type:'Extra sugerido', note:'Balancea costillas, mac & cheese y dressing del coleslaw. Esencial aunque se liste por separado.' },
  { name:'Salsa BBQ', type:'Extra sugerido', note:'Ayuda a lograr textura de glaze BBQ más clásica. Complementa el Bacardi Spice.' },
  { name:'Aceite o mantequilla', type:'Extra sugerido', note:'Ayuda a que los spices se adhieran mejor a los corn ribs durante el asado.' },
  { name:'Agua', type:'Extra sugerido', note:'Necesaria para preparar el simple syrup del postre (1 taza de agua + azúcar).' },
  { name:'Pimienta negra', type:'Opcional', note:'Añade profundidad al dressing del Coleslaw Caribeño. A gusto del chef.' },
];

const CAT_LABELS = {
  appetizer: 'Appetizer — Corn Ribs',
  principal: 'Principal — Costillas BBQ Bacardi Spice',
  side: 'Principal/Side — Jalapeño Mac and Cheese',
  coleslaw: 'Side — Coleslaw Caribeño + Dressing',
  postre: 'Postre — Bizcocho de maíz · Syrup · Mousse',
  miscellaneous: 'Miscellaneous',
};

// ─── STATE ───────────────────────────────────────────────────────────────────

let activeFilter = 'todos';
let searchQuery = '';

function getState() {
  try { return JSON.parse(localStorage.getItem('cookout_state') || '{}'); } catch { return {}; }
}

function saveState(id, field, val) {
  const s = getState();
  if (!s[id]) s[id] = {};
  s[id][field] = val;
  localStorage.setItem('cookout_state', JSON.stringify(s));
}

function isChecked(id, field) {
  const s = getState();
  return !!(s[id] && s[id][field]);
}

// ─── RENDER ──────────────────────────────────────────────────────────────────

function renderAll() {
  renderIngredients();
  renderExtras();
  updateStats();
}

function getVisible() {
  const q = searchQuery.toLowerCase().trim();
  return INGREDIENTS.filter(ing => {
    const catMatch = activeFilter === 'todos'
      || activeFilter === 'extra' && ing.extra
      || ing.cat === activeFilter;
    if (!catMatch) return false;
    if (!q) return true;
    return [ing.name, ing.cat, ing.usedIn, ing.notes, ing.amount]
      .some(f => f && f.toLowerCase().includes(q));
  });
}

function renderIngredients() {
  const container = document.getElementById('ingredientsList');
  const visible = getVisible();
  document.getElementById('visibleCount').textContent = `${visible.length} ingredientes`;

  if (visible.length === 0) {
    container.innerHTML = '<div class="empty-state">No se encontraron ingredientes.</div>';
    return;
  }

  // Group by category
  const cats = [...new Set(visible.map(i => i.cat))];
  const state = getState();

  container.innerHTML = cats.map(cat => {
    const items = visible.filter(i => i.cat === cat);
    const label = CAT_LABELS[cat] || cat;

    const desktopRows = items.map(ing => {
      const chkComprar = isChecked(ing.id, 'comprar');
      const chkTengo = isChecked(ing.id, 'tengo');
      const rowCls = chkComprar ? 'done-comprar' : (chkTengo ? 'done-tengo' : '');
      return `
        <tr class="ingredient-row ${rowCls}" id="row-${ing.id}">
          <td class="td-check">
            <div class="check-wrap check-comprar">
              <input type="checkbox" id="cc-${ing.id}" ${chkComprar?'checked':''} onchange="toggle('${ing.id}','comprar',this.checked)">
            </div>
          </td>
          <td class="td-check">
            <div class="check-wrap check-tengo">
              <input type="checkbox" id="ct-${ing.id}" ${chkTengo?'checked':''} onchange="toggle('${ing.id}','tengo',this.checked)">
            </div>
          </td>
          <td class="td-name">
            ${ing.name}
            ${ing.extra ? '<span class="badge-gold">Extra</span>' : ''}
          </td>
          <td class="td-amount">${ing.amount}</td>
          <td class="td-used">${ing.usedIn}</td>
          <td class="td-notes">${ing.notes}</td>
        </tr>`;
    }).join('');

    const mobileCards = items.map(ing => {
      const chkComprar = isChecked(ing.id, 'comprar');
      const chkTengo = isChecked(ing.id, 'tengo');
      return `
        <div class="mobile-ingredient">
          <div class="mi-top">
            <div class="mi-name">
              ${ing.name}
              ${ing.extra ? '<span class="badge-gold">Extra</span>' : ''}
            </div>
            <div class="mi-amount">${ing.amount}</div>
          </div>
          <div class="mi-note">${ing.usedIn} · ${ing.notes}</div>
          <div class="mi-checks">
            <label class="mi-check-item">
              <input type="checkbox" ${chkComprar?'checked':''} onchange="toggle('${ing.id}','comprar',this.checked)">
              <span class="check-label">Comprar</span>
            </label>
            <label class="mi-check-item">
              <input type="checkbox" ${chkTengo?'checked':''} onchange="toggle('${ing.id}','tengo',this.checked)">
              <span class="check-label">Ya tengo</span>
            </label>
          </div>
        </div>`;
    }).join('');

    return `
      <div class="cat-block" id="cat-${cat}">
        <div class="cat-header" onclick="toggleCat('${cat}')">
          <span class="cat-title">${label}</span>
          <span class="cat-count">${items.length}</span>
          <span class="cat-chevron">▾</span>
        </div>
        <div class="cat-body">
          <table class="ingredient-table">
            <thead>
              <tr>
                <th>Comprar</th>
                <th>Ya tengo</th>
                <th>Ingrediente</th>
                <th>Cantidad</th>
                <th>Usado en</th>
                <th>Notas</th>
              </tr>
            </thead>
            <tbody>${desktopRows}</tbody>
          </table>
          <div class="mobile-cards">${mobileCards}</div>
        </div>
      </div>`;
  }).join('');
}

function renderExtras() {
  document.getElementById('extrasGrid').innerHTML = EXTRAS_NOTES.map(e => `
    <div class="extra-card">
      <div class="extra-card-type">${e.type}</div>
      <div class="extra-card-name">${e.name}</div>
      <div class="extra-card-note">${e.note}</div>
    </div>`).join('');
}

function updateStats() {
  const total = INGREDIENTS.length;
  let comprar = 0, tengo = 0;
  INGREDIENTS.forEach(ing => {
    if (isChecked(ing.id, 'comprar')) comprar++;
    if (isChecked(ing.id, 'tengo')) tengo++;
  });
  const pending = total - comprar - tengo;

  document.getElementById('statTotal').textContent = total;
  document.getElementById('statComprar').textContent = comprar;
  document.getElementById('statTengo').textContent = tengo;
  document.getElementById('statPending').textContent = Math.max(0, pending);

  document.getElementById('pbComprar').style.width = (comprar/total*100).toFixed(1) + '%';
  document.getElementById('pbTengo').style.width = (tengo/total*100).toFixed(1) + '%';
}

// ─── INTERACTIONS ─────────────────────────────────────────────────────────────

function toggle(id, field, val) {
  saveState(id, field, val);
  // Update row class for desktop
  const row = document.getElementById('row-' + id);
  if (row) {
    const chkC = isChecked(id, 'comprar');
    const chkT = isChecked(id, 'tengo');
    row.className = 'ingredient-row' + (chkC ? ' done-comprar' : chkT ? ' done-tengo' : '');
  }
  updateStats();
}

function setFilter(cat) {
  activeFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.cat === cat);
  });
  renderIngredients();
}

function filterAll() {
  searchQuery = document.getElementById('searchInput').value;
  renderIngredients();
}

function toggleCat(cat) {
  const el = document.getElementById('cat-' + cat);
  if (el) el.classList.toggle('collapsed');
}

function resetAll() {
  if (!confirm('¿Resetear todos los checkboxes? Esto borra el progreso guardado.')) return;
  localStorage.removeItem('cookout_state');
  renderAll();
}

// ─── INIT ─────────────────────────────────────────────────────────────────────

renderAll();
</script>
</body>
</html>
